PORT=3003
SESSION_SECRET=local_development_secret_keys
FRONTEND_URL=http://localhost:5173
NODE_ENV=development

# Credenciais Google (Obtenha no Google Cloud Console)
GOOGLE_CLIENT_ID=SUA_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=SUA_GOOGLE_CLIENT_SECRET
GOOGLE_CALLBACK_URL=http://localhost:3003/auth/google/callback

# Credenciais GitHub (Obtenha nas Configurações de Desenvolvedor do GitHub)
GITHUB_CLIENT_ID=SEU_GITHUB_CLIENT_ID
GITHUB_CLIENT_SECRET=SEU_GITHUB_CLIENT_SECRET
GITHUB_CALLBACK_URL=http://localhost:3003/auth/github/callback

# Opcional
SENTRY_DSN=
